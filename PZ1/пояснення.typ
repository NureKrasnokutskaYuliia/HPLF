def print_min1(a, b, c):
    print(min(a, b, c))
/* Функція використовує вбудовану в Python функцію min(), яка автоматично знаходить мінімальне значення серед усіх переданих їй аргументів. Це найкоротший та найшвидший спосіб знайти мінімальне значення. */

def print_min2(a, b, c):
    if a <= b and a <= c:
        print(a)
    elif b <= a and b <= c:
        print(b)
    else:
        print(c)
/* Мета - також знайти та вивести найменше з трьох чисел, але без використання вбудованої функції min(). Спочатку програма перевіряє: якщо a менше або дорівнює b І a менше або дорівнює c, тоді саме a є найменшим числом, і воно виводиться на екран. Якщо перша умова хибна, перевіряється друга: якщо b менше або дорівнює a І b менше або дорівнює c, тоді найменшим є b. Якщо жодна з попередніх умов не спрацювала, методом виключення залишається лише один варіант — найменшим є число c. */

def reverse_string(s):
    return s[::-1]
/* Ця функція має на меті перевернути рядок. У Python для цього використовується slicing з кроком -1. s[::-1] створює копію рядка s, але у зворотному порядку, і саме цю копію функція повертає. */

def is_palindrome(word):
    return word == word[::-1]
/* Мета - визначити, чи є слово паліндромом, тобто чи читається воно однаково з обох боків. Для цього функція порівнює початковий рядок word з його перевернутою версією, яку знову ж таки отримують за допомогою slicing s[::-1]. Якщо ці два рядки рівні, функція повертає True, вказуючи, що слово є паліндромом, якщо ні - False. */

def quicksort(arr):
    if len(arr) <= 1:
        return arr
    pivot = arr[len(arr) // 2]
    left = [x for x in arr if x < pivot]
    middle = [x for x in arr if x == pivot]
    right = [x for x in arr if x > pivot]
    return quicksort(left) + middle + quicksort(right)
/* Мета - відсортувати список чисел за допомогою рекурсивного алгоритму швидкого сортування (quicksort). Алгоритм працює так: якщо список складається з одного елемента або порожній, він вже відсортований і повертається як є. Інакше вибирається "опорний" елемент (у цьому випадку - середній елемент списку), а потім список ділиться на три частини: елементи менші за опорний (left), рівні опорному (middle) та більші за опорний (right). Далі функція рекурсивно викликає сама себе для списків left та right, а потім об'єднує відсортовані частини у фінальний відсортований список. */
